---
	import Layout from '../layouts/Layout.astro';
	import Header from '../components/Header.astro';
	import Contact from '../components/Contact.astro';
	import Footer from '../components/Footer.astro';

	import HeroImage from '../assets/images/store_front.jpg';
	import Showcase01 from '../assets/images/showcase-01.jpg';
	import Showcase02 from '../assets/images/showcase-02.jpg';
	import Showcase03 from '../assets/images/showcase-03.jpg';
	import Showcase04 from '../assets/images/showcase-04.jpg';

	import TeaAffairDesktop from '../assets/images/teaAffair-desktop.png';
	import TeaAffairMobile from '../assets/images/teaAffair-mobile.png';

	import InsideStore01 from '../assets/images/inside_store-01.jpg';
	import InsideStore02 from '../assets/images/inside_store-02.jpg';
	import InsideStore03 from '../assets/images/inside_store-03.jpg';
	import InsideStore04 from '../assets/images/inside_store-04.jpg';
---

<Layout>
	<Header />

	<section class="small-wrapper hero">
        <div class="hero-container">

			<div class="hero-text">
				<h1>Paint. Create. Make It Yours.</h1>
				<p>A creative studio where you can transform blank ceramics into personalized works of art.</p>
			</div>

			<figure>
				<img src={HeroImage.src} alt="Vector characters painting ceramics" class="pics">
			</figure>

        </div>
    </section>

	<!-- <div class="promo-banner">
		<div class="small-wrapper">
			<p><span class="bold">20% OFF</span> In store only ceramics from <span class="bold">June 11th - June 30th</span></p>
		</div>
	</div> -->

	<section id="about" class="small-wrapper section-padding">

		<h2>About</h2>
		<p class="sec-intro-p">Looking for a fun, creative thing to do? We welcome you to Bani's Art Haus where we offer a relaxed, drop-in experience where everyone can come and paint and create at their own pace. There's no need for experience or reservations required. Bani's Art Haus is perfect for family outings, rainy-day activities, creative dates, and casual group get-togethers. <br /><br />Whether you're celebrating a special occasion or simply looking for a unique way to spend an afternoon, we're here to help you create something meaningful.</p>

	</section>

	<div class=" showcase-container">
		<figure>
			<img class="pics" src={Showcase01.src} alt="Child painting a ceramic piece">
		</figure>
		<figure>
			<img class="pics" src={Showcase02.src} alt="Child painting a ceramic piece">
		</figure>
		<figure>
			<img class="pics" src={Showcase03.src} alt="Child painting a ceramic piece">
		</figure>
		<figure>
			<img class="pics" src={Showcase04.src} alt="Child painting a ceramic piece">
		</figure>
	</div>

	<section id="services" class="section-padding">
		<div class="small-wrapper">
			<h2>Services</h2>
			<p class="sec-intro-p">Besides painting on ceramics, we also have unfinished wooden pieces to paint and other unique small art pieces to paint or to conserve as is.</p>

			<div class="teaAffair-service service-row">
				<figure>
					<img class="pics desktopOnly" src={TeaAffairDesktop.src} alt="Tea Affair">
					<img class="pics mobileOnly" src={TeaAffairMobile.src} alt="Tea Affair">
				</figure>
				
				<h3>An Elegant Tea Affair</h3>
				<p>Share an elegant tea service complete with handcrafted treats while expressing your creativity through ceramic painting. Perfect for catching up with friends, celebrating special occasions, or simply enjoying a relaxing afternoon. Give us a call to make a reservation.</p>
				<a href="tel:6572273739" 
					class="pink-cta rsvp-cta"
					title="Make a Reservation"
					aria-label="Link will call phone number 6572273739">Make a Reservation</a>
				<div class="notes-container">
					<h4>A Note To Our Guests:</h4>
					<ul>
						<li>- Please let us know of any food allergies or dietary restrictions.</li>
						<li>- Advance 2 day notice allows us to prepare with care and consideration.</li>
						<li>- Menu items may vary slightly based on availability and season.</li>
						<li>- This package is for dine-in only.</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<Contact />

	<div class=" showcase-container">
		<figure>
			<img class="pics" src={InsideStore01.src} alt="Child painting a ceramic piece">
		</figure>
		<figure>
			<img class="pics" src={InsideStore02.src} alt="Child painting a ceramic piece">
		</figure>
		<figure>
			<img class="pics" src={InsideStore03.src} alt="Child painting a ceramic piece">
		</figure>
		<figure>
			<img class="pics" src={InsideStore04.src} alt="Child painting a ceramic piece">
		</figure>
	</div>


	<Footer />
</Layout>

<style>
	.hero{ height: auto; }
	.hero-container{
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: 100%;
		gap: 0 1rem;
	}
	.hero-text{
		width: 40%;
		min-width: 415px;
		height: auto;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 4.5rem 0;
	}
	.hero-container figure{
		width: 55%;
		height: 65vh;
		max-height: 625px;
		min-height: 380px;
	}
	.hero-container h1{
		font-family: var(--secondary-font);
		font-size: 4rem;
		margin-bottom: 24px;
		font-weight: 400;
	}
	.hero-container .hero-text p{
		padding-right: 1rem;
		font-size: 1.5rem;
		line-height: 1.45;
	}

	.promo-banner{
        padding: 1.5rem 0;
        color: #fff;
        background-color: var(--dark-plum);
    }
    .promo-banner p{
        font-size: 1.125rem;
        text-align: center;
    }
	.showcase-container{
		display: grid;
		grid-template-columns: repeat(4, 1fr);
	}

	.showcase-container figure{ max-height: 350px; }

	/* About Section */
	/* .about-p{margin-top: 2rem;} */

	/* Services Section */
	#services .sec-intro-p{text-align: center;}
	.teaAffair-service{margin-top: 3rem;}
	.service-row h3{margin-bottom: 10px;}
	.service-row p{margin-bottom: 2rem;}
	.rsvp-cta::after{content: 'Make a Reservation';}

	.notes-container{
		margin-top: 2rem;
		margin-bottom: 1rem;
	}
	.notes-container h4{margin-bottom: 10px;}
	.notes-container ul li{margin-bottom: 10px;}
	.notes-container ul li:last-child{margin-bottom: 0;}


	@media screen and (max-width: 1120px){
		.hero-container{
			flex-direction: column;
			justify-content: space-evenly;
		}
		.hero-container .hero-text{
			width: 100%;
			justify-content: center;
			align-items: center;
		}
		.hero-container h1{text-align: center;}
		.hero-container .hero-text p{
			padding-right: 0;
			text-align: center;
		}
		.hero-container figure{
			width: 100%;
			max-height: 600px;
		}
	}

	@media screen and (max-width: 921px){
		.hero-container h1{ font-size: 4rem; }
		.showcase-container{
			grid-template-columns: repeat(2,1fr);
		}
		.showcase-container figure{ max-height: 250px; }
	}
	@media screen and (max-width: 480px){
		.hero-container h1{ font-size: 3.25rem; }
		.hero-text{ min-width: auto; }
		.hero-container figure{
			height: 40vh;
			max-height: 475px;
		}
	}
	@media screen and (max-width: 380px){
		.hero-container .text-container{ height: 50%; }
	}
	
</style>