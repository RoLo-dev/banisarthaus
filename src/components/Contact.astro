<section id="contact" class="section-padding">
    <div class="wrapper contact-container">
        <h2>Contact</h2>
        <p style="text-align: center;">Have questions or would like to make any inquiries please contact us and we will do our best to get back to you quickly.</p>

        <div class="info-container">
            <div class="col col-one">
                <h3>Location Info</h3>
                <ul>
                    <li>
                        <h4>Email</h4>
                        <a href="mailto:banibakery@gmail.com" title="Email" aria-label="Email banibakery@gmail.com"> banibakery@gmail.com</a>
                    </li>
                    <li>
                        <h4>Phone</h4>
                        <a href="tel:7142495911" title="Phone number" aria-label="Phone number 7142495911">(714) 249 - 5911</a>
                    </li>
                    <li>
                        <h4>Address</h4>
                        <a href="https://goo.gl/maps/XsePsz1xZJ2xge2i8" title="Bani's Art Haus address link" aria-label="Google map link for Bani's Art Haus address 7561 Center Ave Suite 7 Huntington Beach, CA 92647" target="_blank">7561 Center Ave Suite 7<br/> Huntington Beach, CA 92647</a>
                    </li>
                    <li>
                        <h4>Store Hours</h4>
                        <ul>
                            <li>
                                <span>Monday</span>
                                <span>CLOSED</span>
                            </li>
                            <li>
                                <span>Tue - Fri:</span>
                                <span>11am - 8pm</span>
                            </li>
                            <li>
                                <span>Sat - Sun:</span>
                                <span>10am - 8pm</span>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
            <div class="col col-two">
                <form action="https://formsubmit.co/banibakery@gmail.com" enctype="multipart/form-data" method="POST" id="contact-form">
					<input type="hidden" name="_template" value="table">
					<input type="text" name="_honey" style="display:none">
					<!-- <input type="hidden" name="subject" value="New subject from %{formName} (%{submissionId})" /> -->
					<input type="hidden" id="subject" name="_subject" value="Contact form submission!">
					<input type="hidden" name="form-name" value="contact">

					<div class="formSimplify">
						<div>
							<label for="name">Full name:</label>
							<span id="name-errorMsg" class="form-error">Enter full name</span>
							<input type="text" id="name" name="name" placeholder="John Doe" required>
						</div>
						<div>
							<label for="phone">Phone:</label>
							<span id="phone-errorMsg" class="form-error">Enter phone number</span>
							<input id="phone" type="tel" name="phone" placeholder="123-321-0909" required>
						</div>
					</div>

					<div class="formSimplify">
						<div>
							<label for="email">Email:</label>
							<span id="email-errorMsg" class="form-error">Enter email</span>
							<input type="email" name="email" id="email" placeholder="youremail@email.com" required>
						</div>
						<div>
							<label for="emailConfirm">Confirm email:</label>
							<span id="emailConfirm-errorMsg" class="form-error"> Email does not match</span>
							<input type="email" name="emailConfirm" id="emailConfirm">
						</div>
					</div>

					<!-- <div class="formSimplify">
						<div>
							<label for="date">Due date:</label>
							<span id="date-errorMsg" class="form-error">Enter due date</span>
							<input id="date" type="date" name="date" required>
						</div>
						<div>
							<label for="time">Pickup Time:</label>
							<span id="time-errorMsg" class="form-error">Enter pickup time</span>
							<input id="time" type="time" name="">
							<input type="hidden" id="formattedTime" name="time">
						</div>
					</div> -->

					<!-- <div class="formSimplify">
						<div>
							<label for="servings">Servings needed:</label>
							<span id="servings-errorMsg" class="form-error">How many servings?</span>
							<input id="servings" type="number" name="servings" required>
						</div>
						<div>
							<input type="file" class="file-upload" name="attachment" accept="image/png, image/jpeg, image/jpg">
						</div>
					</div> -->

					<div>
						<label for="message">Message:</label>
						<textarea name="message"></textarea>
					</div>

					<button tabindex="0" class="submit-btn pink-cta" title="Submit" aria-label="Submit button for form" >SUBMIT</button>
					<input id="validation-complete" type="submit" value="submit" style="display: none;">
				</form>
            </div>
        </div>
    </div>
</section>

<style>
    h2{
        text-align: center;
        margin-bottom: 1.5rem;
    }
    h3{margin-bottom: 1rem;}
    h4{margin-bottom: 5px;}
    .info-container{
        margin-top: 6rem;
        display: flex;
        justify-content: space-evenly;
    }



    form{
		display: flex;
		flex-direction: column;
		gap: 1.25rem 0;
	}
    form label{font-weight: 500;}
	form label, form input, form textarea{
		width: 100%;
		display: block;
		color: var(--dark-plum);
	}
    form input, form textarea{
		font-size: 1.1rem;
		border: 0;
		background-color: var(--soft-gray);
	}
    form input:active, form textarea:active,
	form input:focus, form textarea:focus{
		background-color: #fff;
	}
	form input{
		padding: 0 5px;
		height: 2.75rem;
	}
	form textarea{
		height: 10rem;
		padding: 5px;
	}

    .formSimplify{
		display: flex;
        /* flex-direction: column; */
		align-items: center;
		justify-content: space-between;
	}
    .formSimplify div{width: 48%;}
	.form-error{display: none;}
	.submit-btn::after{content: 'SUBMIT';}
</style>