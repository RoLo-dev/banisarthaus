---
    import logo from '../assets/images/BanisArtHaus-logo-white_md.png';
---

<footer>
    <div class="footer-container wrapper">
        <a href="/" title="Bani Bakery logo" aria-label="Logo image, a link to homepage" class="footer-logo">
            <img loading="lazy" src={logo.src} alt="Bani bakery logo" class="pics">
        </a>
        <div class="ftLinks">
            <h4>Bani's Art Haus</h4>
            <ul>
                <li><a href="/#about" title="About" aria-label="Link to about section">About</a></li>
                <li><a href="/#services" title="Services link" aria-label="Link to services section">Services</a></li>
                <li><a href="/#contact" title="Contact link" aria-label="Link to contact section">Contact</a></li>
            </ul>
        </div>
        <div class="business-info">
            <div class="business-contact">
                <h4>Contact</h4>
                <ul>
                    <li>
                        <a href="mailto:banibakery@gmail.com" title="Email" aria-label="Email banibakery@gmail.com"> banibakery@gmail.com</a>
                    </li>
                    <li>
                        <a href="tel:7142495911" title="Phone number" aria-label="Phone number 7142495911">(714) 249 - 5911</a>
                    </li>
                    <li>
                        <a href="https://goo.gl/maps/XsePsz1xZJ2xge2i8" title="Bani's Art Haus address link" aria-label="Google map link for Bani's Art Haus address 7561 Center Ave Suite 7 Huntington Beach, CA 92647" target="_blank">7561 Center Ave Suite 7<br/> Huntington Beach, CA 92647</a>
                    </li>
                </ul>
            </div>
            <div class="footer-social">
                <h4 class="social">Social</h4>
                <ul class="socialList">
                    <li>
                        <a href="https://www.facebook.com/banibakery/" title="Facebook" aria-label="Link to facebook page" target="_blank"><i class="fa-brands fa-facebook"></i></a>
                    </li>
                    <li>
                        <a href="https://www.instagram.com/banihouseofcakes/" title="Instagram" aria-label="Link to instagram page" target="_blank"><i class="fa-brands fa-instagram"></i></a>
                    </li>
                    <!-- <li>
                        <a href="https://www.yelp.com/biz/bani-bakery-santa-ana" title="Yelp" aria-label="Link to yelp page" target="_blank"><i class="fa-brands fa-yelp"></i></a>
                    </li> -->
                </ul>
            </div>
        </div>
        <div class="store-hours">
            <h4>Store Hours</h4>
            <ul>
                <li>
                    <span>Monday</span>
                    <span>CLOSED</span>
                </li>
                <li>
                    <span>Tue - Fri:</span>
                    <span>11am - 8pm</span>
                </li>
                <li>
                    <span>Sat - Sun:</span>
                    <span>10am - 8pm</span>
                </li>
            </ul>
        </div>

    </div>
    <p class="wrapper">&copy; <span id="footer-year"></span> Bani's Art Haus All Rights Reserved.</p>
</footer>

<style>
    footer{
        background-color: var(--dark-plum);
        padding: 2rem;
        /* color: var(--cream); */
        color: #fff;
    }
</style>

<script>
    let currentDay = new Date();
    let year = currentDay.getFullYear();
    let footerYear = document.getElementById('footer-year');

    function updateYear() {
        if(footerYear != null){
            footerYear.innerText = year.toString();
        }
    }
    updateYear();
</script>